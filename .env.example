# ─────────────────────────────────────────────
# Quartel Digital — recrutapadrao-checklist
# Copie este arquivo para .env.local e preencha
# ─────────────────────────────────────────────

# WhatsApp
# Número no formato internacional sem + (ex: 5521999999999)
NEXT_PUBLIC_WHATSAPP_NUMBER=

# ─── Supabase ────────────────────────────────
# Instale: npm install @supabase/supabase-js
# Ative: descomente o código em lib/supabase.ts
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Google Analytics 4 ──────────────────────
# ID do seu stream (ex: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# ─── Microsoft Clarity ───────────────────────
# ID do projeto (ex: abcdefghij)
NEXT_PUBLIC_CLARITY_ID=

# ─── Meta Pixel ──────────────────────────────
# Descomentado quando ativar campanhas
# NEXT_PUBLIC_META_PIXEL_ID=

# ─── UTMs (leitura automática via URL) ───────
# Não é necessário configurar aqui.
# O formulário lê utm_source, utm_medium, utm_campaign da URL.
