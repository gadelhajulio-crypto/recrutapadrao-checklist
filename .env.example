# Copie para .env.local e preencha os valores
# .env.local NÃO é commitado (ver .gitignore)

# ─── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://checklist.recrutapadrao.com.br

# ─── WhatsApp (tela de sucesso) — formato internacional sem + ─────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=

# ─── Analytics ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_CLARITY_ID=

# ─── Supabase (servidor apenas — nunca usar NEXT_PUBLIC_ aqui) ───────────────
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ─── Evolution API (WhatsApp gateway) ────────────────────────────────────────
EVOLUTION_API_URL=http://127.0.0.1:8080
EVOLUTION_API_KEY=
# Nome da instância — criar com: bash scripts/setup-evolution.sh
EVOLUTION_INSTANCE_NAME=quartel-digital

# ─── Entrega do PDF ───────────────────────────────────────────────────────────
# URL pública do PDF do Checklist (Google Drive, S3, Supabase Storage…)
CHECKLIST_PDF_URL=

# ─── n8n (opcional — automação avançada) ─────────────────────────────────────
N8N_WEBHOOK_URL=
